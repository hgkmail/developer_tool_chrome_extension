{
  "name": "AK Tools Extension",
  "description": "A chrome extension contains some useful developer tools",
  "version": "0.0.1",
  "manifest_version": 3,
  "action": {
    "default_title": "Click to open tools"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
